{
    "name": "wprigel/pollify",
    "description": "Create poll using gutenberg way.",
    "require-dev": {
        "squizlabs/php_codesniffer": "^3.5",
        "dealerdirect/phpcodesniffer-composer-installer": "^0.7.1",
        "wp-coding-standards/wpcs": "^2.3",
        "sirbrillig/phpcs-variable-analysis": "^2.10",
        "automattic/vipwpcs": "^2.2"
    },
    "autoload": {
        "psr-4": {
            "UnderDev\\Pollify\\": "includes/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "UnderDev\\Pollify\\Tests\\": "tests/php"
        }
    },
    "scripts": {
        "cs": "@php ./vendor/bin/phpcs . --ignore=tests",
        "cs:fix": "@php ./vendor/bin/phpcbf plugins.php src/",
        "tests:unit": "@php ./vendor/bin/phpunit tests/php/Unit/",
        "qa": [
            "@cs",
            "@tests"
        ]
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
