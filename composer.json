{
    "name": "wprigel/pollify",
    "description": "Create poll using gutenberg way.",
    "require-dev": {
        "wp-coding-standards/wpcs": "^3.0",
        "phpcompatibility/phpcompatibility-wp": "*",
        "sirbrillig/phpcs-variable-analysis": "^2.11"
    },
    "autoload": {
        "psr-4": {
            "wpRigel\\Pollify\\": "includes/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "wpRigel\\Pollify\\Tests\\": "tests/php"
        }
    },
    "scripts": {
        "cs": "@php ./vendor/bin/phpcs . --ignore=tests",
        "cs:fix": "@php ./vendor/bin/phpcbf . --ignore=tests",
        "tests:unit": "@php ./vendor/bin/phpunit tests/php/Unit/",
        "qa": [
            "@cs",
            "@tests"
        ]
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
